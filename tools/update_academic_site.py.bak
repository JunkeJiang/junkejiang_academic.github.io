def bib_field(text: str, name: str) -> str:
    match = re.search(rf"\b{name}\s*=\s*(?:\{{(.*?)\}}|\"(.*?)\"|([^,\n]+))", text, flags=re.S | re.I)
    if not match:
        return ""
    value = next(group for group in match.groups() if group is not None)
    value = value.replace("\n", " ")
    value = value.replace("--", "-")
    value = re.sub(r"\s+", " ", value).strip()
    return value.strip("{} ")


